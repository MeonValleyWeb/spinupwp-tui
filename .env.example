# Copy to .env and fill in your SpinupWP API token.
# Create a token at https://spinupwp.app/account/api/ (Read Only is enough).
SPINUPWP_ACCESS_TOKEN=your-token-here

# Optional: override the SSH user for the live server health view (`h`).
# By default it connects as a site_user@<server-ip> derived from the API.
# Set this to e.g. "root" if you SSH in as a different user.
# SPINUPWP_SSH_USER=root
